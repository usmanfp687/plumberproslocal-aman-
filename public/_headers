/*
  # Security Headers
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: index, follow
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.clarity.ms https://leadslytic.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://unpkg.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://www.clarity.ms; frame-src https://maps.google.com;

# CSS - immutable (hashed in build, 1 year)
/css/*
  Cache-Control: public, max-age=31536000, immutable

# Images - 30 days with stale-while-revalidate
/assets/images/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# SVG / ICO - 30 days
/*.svg
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/*.ico
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# Sitemaps - 6 hours
/sitemap*.xml
  Cache-Control: public, max-age=21600, stale-while-revalidate=3600

# Robots & LLMs - 1 day
/robots.txt
  Cache-Control: public, max-age=86400

/llms.txt
  Cache-Control: public, max-age=86400

# HTML pages - always revalidate but serve stale for 1 hour
/*.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=600
  Vary: Accept-Encoding
