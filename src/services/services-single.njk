---
layout: layout.njk
pagination:
  data: services
  size: 1
  alias: service
permalink: "services/{{ service.slug }}/index.html"
eleventyComputed:
  title: "{{ service.title }} Near You | Same Day Service | Local Electrician Emergency"
  description: "{{ service.title }} near you. Call {{ site.PHONE }} for professional and reliable local electrical services. Same day available."
---

{# ——— Schemas —————————————————————————————————————————————————————————— #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Electrician",
  "name": "{{ service.title }} - {{ site.BRAND }}",
  "url": "{{ site.DOMAIN }}/services/{{ service.slug }}/",
  "image": "{{ site.DOMAIN }}/favicon.svg",
  "telephone": "{{ site.PHONE }}",
  "priceRange": "$"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.DOMAIN }}/" },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": "{{ site.DOMAIN }}/services/" },
    { "@type": "ListItem", "position": 3, "name": "{{ service.title }}", "item": "{{ site.DOMAIN }}/services/{{ service.slug }}/" }
  ]
}
</script>


{# ── Breadcrumb ────────────────────────────────────────────────────────── #}
<div class="breadcrumb-bar">
  <div class="container">
    <div class="bc-inner" id="svcBreadcrumb">
      <i class="ph ph-house" style="font-size:13px"></i>
      <a href="/">Home</a>
      <span class="bc-sep">›</span>
      <a href="/services/">Our Services</a>
      <span class="bc-sep">›</span>
      <span>{{ service.title }}</span>
    </div>
  </div>
</div>

{# ── Banner ────────────────────────────────────────────────────────────── #}
<div class="rs-banner">
  <div class="container">
    <div class="banner-row">
      <div class="banner-content-col">
        <div class="banner-content">
          <div class="sub-label">
            <i class="ph ph-map-pin" style="font-size:12px"></i>
            Professional Electrical
          </div>
          <h1 class="title">
            {{ service.title }} <span id="svcLocationSpan">Near You</span>
          </h1>
          <p class="description" id="svcBannerDesc">
            {{ service.description }} At {{ site.BRAND }}, our licensed electricians are standing by for
            same day service and 24/7 emergency response.
          </p>
          <div class="btn-part">
            <a class="readon orange" href="{{ site.PHONE_HREF }}">
              <i class="ph ph-phone-call" style="font-size:17px"></i>
              {{ site.PHONE }}
            </a>
          </div>
        </div>
      </div>
      <div class="banner-img-box">
        <img src="/assets/images/{{ service.image or 'global-hero.webp' }}" alt="{{ service.title }} services by expert local electrical contractors near you. Call {{ site.BRAND }} for same day repairs.">
      </div>
    </div>
  </div>
</div>

{# ── Content ───────────────────────────────────────────────────────────── #}
<div class="rs-choose" style="background:var(--gray-bg)">
  <div class="container">
    <div class="choose-grid">
      <div>
        <div class="sec-title4">
          <div class="sub-line"></div>
          <span class="sub-text">
            <i class="ph ph-info" style="font-size:13px"></i>
            About This Service
          </span>
          <h2>Expert {{ service.title }} <span id="svcLocH2">Near You</span></h2>
          <p>
            When you need {{ service.title | lower }} near you,
            {{ site.BRAND }} provides industry-leading expertise and rapid response. Electrical
            problems can escalate quickly if left untreated, leading to catastrophic electrical fires, 
            fatal shocks, and severe property damage. Explore all of our
            <a href="/services/" id="svcAllLink" style="color:var(--primary);text-decoration:underline">professional electrical services</a>.
          </p>
          <p>
            Our licensed electricians use professional-grade tools and techniques to
            properly diagnose and fix the issue the first time. We offer upfront
            pricing with no hidden fees, and back all our work with a strict safety guarantee.
          </p>
          <div style="margin-top:26px">
            <a class="readon orange" href="{{ site.PHONE_HREF }}">
              <i class="ph ph-phone-call" style="font-size:17px"></i>
              {{ site.PHONE }}
            </a>
          </div>
        </div>
      </div>
      <div class="choose-img">
        <img src="/assets/images/{{ service.image or 'global-hero.webp' }}" alt="Professional {{ service.title }} company near you. Licensed electricians providing top-rated electrical services." loading="lazy">
      </div>
    </div>
  </div>
</div>



{# ── CTA Strip ─────────────────────────────────────────────────────────── #}
<div class="cta-strip">
  <div class="container">
    <h2 id="svcCtaH2">Need {{ service.title }} Near You?</h2>
    <p>Don't wait. Our licensed local electricians are available same day and 24/7 for emergencies.</p>
    <a class="readon orange" href="{{ site.PHONE_HREF }}">
      <i class="ph ph-phone-call" style="font-size:18px"></i>
      {{ site.PHONE }} — Free Estimate
    </a>
  </div>
</div>

{# ── Client-Side Location Detection ───────────────────────────────────── #}
<script>
(function () {
  var SVC_TITLE = {{ service.title | dump | safe }};
  var SVC_DESC  = {{ service.description | dump | safe }};

  var userLocStr = localStorage.getItem('userLoc');
  if (!userLocStr) return;

  var loc;
  try {
    loc = JSON.parse(userLocStr);
  } catch (e) {
    return;
  }

  var locText = 'in ' + loc.stateName;
  if (loc.cityName) {
    locText = 'in ' + loc.cityName + ', ' + loc.stateAbbr;
  }

  // h1 span
  var locSpan = document.getElementById('svcLocationSpan');
  if (locSpan) locSpan.textContent = locText;

  // h2 in content
  var locH2 = document.getElementById('svcLocH2');
  if (locH2) locH2.textContent = locText;

  // Banner description — replace "near you" with location
  var desc = document.getElementById('svcBannerDesc');
  if (desc) {
    var newDesc = SVC_DESC.replace(/near you/gi, locText.toLowerCase());
    desc.textContent = newDesc + ' At {{ site.BRAND }}, our licensed electricians are standing by for same day service and 24/7 emergency response.';
  }

  // CTA h2
  var ctaH2 = document.getElementById('svcCtaH2');
  if (ctaH2) ctaH2.textContent = 'Need ' + SVC_TITLE + ' ' + locText + '?';

  // All services link (keep clean URL)
  var allLink = document.getElementById('svcAllLink');
  if (allLink) allLink.setAttribute('href', '/services/');

  // Breadcrumb
  var bc = document.getElementById('svcBreadcrumb');
  if (bc) {
    var extra = '';
    if (loc.stateSlug) extra += '<span class="bc-sep">›</span><a href="/' + loc.stateSlug + '/">' + loc.stateName + '</a>';
    if (loc.citySlug) extra += '<span class="bc-sep">›</span><a href="/' + loc.stateSlug + '/' + loc.citySlug + '/">' + loc.cityName + '</a>';
    bc.innerHTML = '<i class="ph ph-house" style="font-size:13px"></i>'
      + '<a href="/">Home</a>' + extra
      + '<span class="bc-sep">›</span><a href="/services/">Our Services</a>'
      + '<span class="bc-sep">›</span><span>' + SVC_TITLE + '</span>';
  }

  // Document title
  document.title = SVC_TITLE + ' ' + locText + ' | Same Day Service | {{ site.BRAND }}';
})();
</script>
