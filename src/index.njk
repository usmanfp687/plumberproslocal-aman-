---
layout: layout.njk
title: "Top-Rated Local Plumbers Near You | 24/7 Emergency Plumbing Services"
description: "Need a local plumber near you? We provide 24/7 emergency plumbing services, fast drain cleaning, water heater repairs, and leak detection. Call our licensed plumbing experts today!"
---

{# ── JSON-LD Schemas ────────────────────────────────────────────────────── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "{{ site.BRAND }}",
  "url": "{{ site.DOMAIN }}/",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "{{ site.DOMAIN }}/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Plumber",
  "name": "{{ site.BRAND }}",
  "url": "{{ site.DOMAIN }}/",
  "image": "{{ site.DOMAIN }}/favicon.svg",
  "telephone": "{{ site.PHONE }}",
  "priceRange": "$$",
  "logo": "{{ site.DOMAIN }}/favicon.svg",
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "{{ site.PHONE }}",
    "contactType": "customer service",
    "areaServed": "US",
    "availableLanguage": "en"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.DOMAIN }}/" }
  ]
}
</script>

{# ── Service Icon Map ──────────────────────────────────────────────────── #}
{% set serviceIcons = {
  'emergency-plumber': 'ph-siren',
  'wiring-rewiring': 'ph-lightbulb',
  'water-heater-repair': 'ph-thermometer',
  'plumbing-panel-upgrade': 'ph-circuit-board',
  'switch-repair-installation': 'ph-switch',
  'fixture-repair-installation': 'ph-fixture',
  'outlet-switch-installation': 'ph-plug',
  'garbage-disposal-repair': 'ph-gear',
  'leak-detection-repair': 'ph-drop',
  'bathroom-plumbing': 'ph-bathtub',
  'kitchen-plumbing': 'ph-cooking-pot',
  'water-filtration': 'ph-waves',
  'sump-pump-services': 'ph-pump',
  'gas-line-services': 'ph-flame',
  'repiping-services': 'ph-arrows-counter-clockwise',
  'circuit-breaker-repair': 'ph-wind',
  'commercial-plumbing': 'ph-buildings',
  'backflow-prevention': 'ph-shield-check'
} %}

{# ── Banner ────────────────────────────────────────────────────────────── #}
<div class="rs-banner">
  <div class="container">
    <div class="banner-row">
      <div class="banner-content-col">
        <div class="banner-content">
          <div class="sub-label">
            <i class="ph ph-map-pin" style="font-size:12px"></i>
            Top-Rated Local Plumbing Experts
          </div>
          <h1 class="title">
            The Best Plumber <span>Near Me</span>
          </h1>
          <p class="description">
            {{ site.BRAND }} connects you with highly-rated, licensed local plumbers across the USA.
            We specialize in rapid-response <strong>emergency plumbing near you</strong>, affordable <strong>drain cleaning</strong>, 
            water heater repair &amp; installation, complete pipe leak repair, toilet repair, 
            and 24-hour same day plumbing service. When you search for a "plumber near me," we are ready to assist. Call 24/7.
          </p>
          <div class="btn-part">
            <a class="readon orange" href="{{ site.PHONE_HREF }}">
              <i class="ph ph-phone-call" style="font-size:17px"></i>
              {{ site.PHONE }}
            </a>
          </div>
        </div>
      </div>
      <div class="banner-img-box">
        <picture>
          <source media="(max-width: 767px)" srcset="/assets/images/mobile_hero.png">
          <img src="/assets/images/global_hero.png" alt="Professional plumber at work" width="800" height="600" loading="eager" decoding="async">
        </picture>
      </div>
    </div>
  </div>
</div>



{# ── Counter ───────────────────────────────────────────────────────────── #}
<div class="rs-counter">
  <div class="container">
    <div class="counter-grid">
      <div class="counter-list">
        <div class="counter-text">
          <div class="counter-icon"><i class="ph ph-lightning" style="font-size:26px;color:#fff"></i></div>
          <div class="counter-number">
            <div class="count-row"><span class="rs-count">500,000</span><span class="prefix">+</span></div>
            <h5 class="title">Jobs Completed</h5>
          </div>
        </div>
      </div>
      <div class="counter-list">
        <div class="counter-text">
          <div class="counter-icon"><i class="ph ph-star" style="font-size:26px;color:#fff"></i></div>
          <div class="counter-number">
            <div class="count-row"><span class="rs-count">4.9</span><span class="prefix">★</span></div>
            <h5 class="title">Average Rating</h5>
          </div>
        </div>
      </div>
      <div class="counter-list">
        <div class="counter-text">
          <div class="counter-icon"><i class="ph ph-clock" style="font-size:26px;color:#fff"></i></div>
          <div class="counter-number">
            <div class="count-row"><span class="rs-count">24</span><span class="prefix">/7</span></div>
            <h5 class="title">Same Day Service</h5>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{# ── Services Grid ─────────────────────────────────────────────────────── #}
<div class="rs-services">
  <div class="container">
    <h2>Professional Local Plumbing Services Near You</h2>
    <div class="services-row">
      {% for svc in services %}
      <div class="services-slider">
        <div class="services-item">
          <a href="/services/{{ svc.slug }}/" class="card-link" aria-label="View {{ svc.title }}"></a>
          
          {% if svc.image %}
          <div class="services-card-img">
            <img src="/assets/images/{{ svc.image }}" alt="{{ svc.title }}" loading="lazy">
          </div>
          {% endif %}
          <div class="services-icon-bar">
            <div class="svc-icon">
              <i class="ph {{ serviceIcons[svc.slug] or 'ph-lightning' }}"></i>
            </div>
          </div>
          <div class="services-content">
            <h3 class="title">
              <a href="/services/{{ svc.slug }}/">{{ svc.title }} Near You</a>
            </h3>
            <p class="description">
              Looking for {{ svc.title | lower }} near you? Contact {{ site.BRAND }} at
              {{ site.PHONE }} for professional services. {{ svc.description.split('.')[0] }}.
            </p>
            <div class="services-btn">
              <a href="{{ site.PHONE_HREF }}">
                <span class="btn-text">Get Quotes</span>
                <span class="arrow-icon">
                  <i class="ph ph-arrow-right" style="font-size:12px"></i>
                </span>
              </a>
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

{# ── States / USA Map ──────────────────────────────────────────────────── #}
<div class="rs-addon-services">
  <div class="container">
    <h2>
      <i class="ph ph-map-trifold" style="font-size:28px;color:var(--primary);margin-right:8px;vertical-align:middle"></i>
      Local Plumbers Available Nationwide
    </h2>

    <div class="interactive-usa-map">
      {% include "usa-map.njk" %}
    </div>

    <div class="addon-row">
      {% for st in states %}
      <a href="/{{ st.slug }}/" class="addon-item" style="text-decoration:none">
        <div class="services-text">
          <div class="services-title">
            <i class="ph ph-map-pin" style="font-size:13px;color:var(--primary);flex-shrink:0"></i>
            <h3>{{ st.name }}</h3>
          </div>
          <div class="location-meta">
            <i class="ph ph-buildings" style="font-size:11px"></i>
            {{ st.abbr }} · {{ st.cities.length }} cities
          </div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</div>

{# ── CTA Strip ─────────────────────────────────────────────────────────── #}
<div class="cta-strip">
  <div class="container">
    <h2>Need a Plumber Today? Call Now — Same Day Service</h2>
    <p>Our licensed local plumbers are standing by for same day and emergency service.</p>
    <a class="readon orange" href="{{ site.PHONE_HREF }}">
      <i class="ph ph-phone-call" style="font-size:18px"></i>
      {{ site.PHONE }} — Free Estimate
    </a>
  </div>
</div>

<script>
  // If the user navigates back to the homepage, clear their contextual location
  // so they see "Near You" instead of being stuck in the last visited state.
  localStorage.removeItem('userLoc');
</script>
