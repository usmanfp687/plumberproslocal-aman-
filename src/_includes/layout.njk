<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ (title | safe) if title else (site.BRAND + " | Same Day Electrical Service") }}</title>
  <meta name="description" content="{{ (description | safe) if description else 'Professional electrical services near you. Emergency electrician, wiring upgrade, panel repair & installation, outlet repair, switch & fixture repair, circuit breaker service & more. Call 24/7.' }}">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="canonical" href="{{ site.DOMAIN }}{{ page.url }}">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="geo.region" content="US">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.ico">

  {# Open Graph #}
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.BRAND }}">
  <meta property="og:title" content="{{ (title | safe) if title else (site.BRAND + ' | Same Day Electrical Service') }}">
  <meta property="og:description" content="{{ (description | safe) if description else 'Professional electrical services near you. Emergency electrician, wiring upgrade, panel repair & installation, outlet repair, switch & fixture repair, circuit breaker service & more. Call 24/7.' }}">
  <meta property="og:url" content="{{ site.DOMAIN }}{{ page.url }}">
  <meta property="og:image" content="{{ site.DOMAIN }}/assets/images/global-hero.webp">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ (title | safe) if title else (site.BRAND + ' | Same Day Electrical Service') }}">
  <meta name="twitter:description" content="{{ (description | safe) if description else 'Professional electrical services near you. Emergency electrician, wiring upgrade, panel repair & installation, outlet repair, switch & fixture repair, circuit breaker service & more. Call 24/7.' }}">
  <meta name="twitter:image" content="{{ site.DOMAIN }}/assets/images/global-hero.webp">

  {# Phosphor Icons preconnect #}
  <link rel="preconnect" href="https://unpkg.com">

  {# Stylesheet #}
  <link rel="stylesheet" href="/css/globals.css">

  {# JSON-LD Schemas injected from page data #}
  {% if schemas %}
    {% for schema in schemas %}
      <script type="application/ld+json">{{ schema | dump | safe }}</script>
    {% endfor %}
  {% endif %}
  <!-- Analytics & Tracking -->
  <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "xjbpyirkhj");
  </script>
  <script src="https://leadslytic.com/widget.js" data-id="20c5e82a-52f4-43c9-b0d3-c90ba2e69b2d" defer></script>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-QEE10Q0T6E"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-QEE10Q0T6E');
  </script>
</head>
<body>

