<script>
document.getElementById('contactForm').addEventListener('submit', function(e) {
  e.preventDefault();
  
  const form = this;
  const formData = new FormData(form);
  
  // Disable button to prevent double submit
  const btn = form.querySelector('button[type="submit"]');
  const btnText = btn.innerHTML;
  if(btn) {
    btn.disabled = true;
    btn.innerHTML = 'Sending...';
  }

  fetch('https://leadslytic.com/api/f/20c5e82a-52f4-43c9-b0d3-c90ba2e69b2d', {
    method: 'POST',
    body: formData
  }).then(response => {
    // Show Toast
    showToast('Your request has been successfully sent! We will contact you shortly.');
    
    // Hide form and show success message
    form.style.display = 'none';
    const successMsg = document.getElementById('formSuccess');
    if(successMsg) successMsg.style.display = 'block';
  }).catch(error => {
    showToast('Something went wrong. Please try again or call us directly.');
    if(btn) {
      btn.disabled = false;
      btn.innerHTML = btnText;
    }
  });
});

function showToast(message) {
  let toast = document.getElementById('leads-toast');
  if (!toast) {
    toast = document.createElement('div');
    toast.id = 'leads-toast';
    toast.style.cssText = 'position:fixed;bottom:30px;right:30px;background:#10b981;color:#fff;padding:16px 24px;border-radius:8px;box-shadow:0 10px 25px rgba(0,0,0,0.2);font-weight:600;z-index:9999;transition:opacity 0.3s;opacity:0;font-family:system-ui,sans-serif;';
    document.body.appendChild(toast);
  }
  toast.innerText = message;
  toast.style.opacity = '1';
  
  setTimeout(() => {
    toast.style.opacity = '0';
  }, 4000);
}

// Urgency pill radio toggle
document.querySelectorAll('.urgency-pill').forEach(function(label) {
  label.addEventListener('click', function() {
    document.querySelectorAll('.urgency-pill').forEach(l => l.classList.remove('active'));
    this.classList.add('active');
  });
});
</script>
